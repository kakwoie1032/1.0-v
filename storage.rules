rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default Deny-All Net
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Media & Image Upload Directory for lunches / notices
    match /uploads/{allPaths=**} {
      allow read: if request.auth != null;
      // Allow only teachers & admins to upload images/files to class uploads directory
      allow write: if request.auth != null && (
        firestore.get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        firestore.get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }
  }
}
